<Window x:Class="_7t2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Шифр Порта. Вариант 14"
        Height="680"
        Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.ColumnSpan="2"
                   Margin="0,0,0,10"
                   FontSize="20"
                   FontWeight="Bold"
                   Text="Шифр Порта. Вариант 14" />

        <GroupBox Grid.Row="1"
                  Grid.Column="0"
                  Margin="0,0,10,10"
                  Header="Текст">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Исходный текст:" />
                <TextBox x:Name="SourceTextBox"
                         Grid.Row="1"
                         Margin="0,5,0,10"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         ToolTip="Введите слова для шифрования или коды для дешифрования." />

                <TextBlock Grid.Row="2" Text="Результат:" />
                <TextBox x:Name="ResultTextBox"
                         Grid.Row="3"
                         Margin="0,5,0,0"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         Background="#FFF5F5F5"
                         ToolTip="Здесь отображается результат операции." />
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="1"
                  Grid.Column="1"
                  Grid.RowSpan="2"
                  Header="Таблица кодов">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="CodebookDataGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          SelectionMode="Single"
                          ToolTip="Таблица замен для шифрования и дешифрования.">
                    <DataGrid.Columns>
                        <DataGridTextColumn Width="*"
                                            Header="Слово"
                                            Binding="{Binding SourceWord, UpdateSourceTrigger=PropertyChanged}" />
                        <DataGridTextColumn Width="*"
                                            Header="Код"
                                            Binding="{Binding Code, UpdateSourceTrigger=PropertyChanged}" />
                    </DataGrid.Columns>
                </DataGrid>

                <WrapPanel Grid.Row="1" Margin="0,10,0,0">
                    <Button Margin="0,0,10,10"
                            Padding="12,6"
                            Click="LoadDefaultTableButton_Click"
                            ToolTip="Загрузить стандартную таблицу кодов."
                            Content="Таблица по умолчанию" />
                    <Button Margin="0,0,10,10"
                            Padding="12,6"
                            Click="AddRowButton_Click"
                            ToolTip="Добавить новую строку в таблицу."
                            Content="Добавить строку" />
                    <Button Margin="0,0,10,10"
                            Padding="12,6"
                            Click="DeleteRowButton_Click"
                            ToolTip="Удалить выбранную строку."
                            Content="Удалить строку" />
                </WrapPanel>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="2"
                  Grid.Column="0"
                  Margin="0,0,10,10"
                  Header="Действия">
            <StackPanel Margin="10">
                <WrapPanel Margin="0,0,0,10">
                    <Button Margin="0,0,10,10"
                            Padding="14,6"
                            Click="EncryptButton_Click"
                            ToolTip="Зашифровать текст по таблице кодов."
                            Content="Зашифровать" />
                    <Button Margin="0,0,10,10"
                            Padding="14,6"
                            Click="DecryptButton_Click"
                            ToolTip="Расшифровать текст по таблице кодов."
                            Content="Расшифровать" />
                    <Button Margin="0,0,10,10"
                            Padding="14,6"
                            Click="ClearButton_Click"
                            ToolTip="Очистить поля ввода и результата."
                            Content="Очистить" />
                </WrapPanel>

                <TextBlock FontWeight="Bold" Text="Сообщение о состоянии:" />
                <TextBlock x:Name="StatusTextBlock"
                           Margin="0,5,0,10"
                           TextWrapping="Wrap"
                           Text="Приложение готово к работе." />

                <TextBlock FontWeight="Bold" Text="Ошибки:" />
                <TextBox x:Name="ErrorTextBox"
                         Margin="0,5,0,0"
                         Height="120"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         Background="#FFFFF0F0"
                         ToolTip="Здесь отображаются ошибки валидации и обработки." />
            </StackPanel>
        </GroupBox>
    </Grid>
</Window>
